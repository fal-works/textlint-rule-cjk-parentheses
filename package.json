{
  "name": "@fal-works/textlint-rule-cjk-parentheses",
  "version": "0.1.0",
  "description": "textlint rule: normalize round parentheses by CJK content and/or context",
  "keywords": [
    "textlintrule",
    "cjk",
    "parentheses"
  ],
  "homepage": "https://github.com/fal-works/textlint-rule-cjk-parentheses#readme",
  "bugs": {
