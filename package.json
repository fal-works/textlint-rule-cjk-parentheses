  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/fal-works/textlint-rule-cjk-parentheses.git"
  },
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "publishConfig": {
